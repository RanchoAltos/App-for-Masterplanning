    setError("");setAnalysis(null);setDemoMode(false);setMapLayer("dem");
    clearInterval(demoRef.current);if(watchRef.current!=null){navigator.geolocation?.clearWatch(watchRef.current);watchRef.current=null;}
    setIsTracking(false);
  };

  const distVal=points.length>1?Math.round(totalDist(points)||0):0;
  const b2=bnds(points);
  const areaVal=b2&&!isNaN(b2.minLat)?Math.round(((b2.maxLat-b2.minLat)*111000*(b2.maxLng-b2.minLng)*111000*Math.cos(b2.minLat*Math.PI/180))||0):0;
  const lastPt=points.length?points[points.length-1]:null;
  const utmLive=(lastPt&&!isNaN(lastPt.lat)&&!isNaN(lastPt.lng))?latLngToUTM(lastPt.lat,lastPt.lng):null;
  const as=analysis?.zones?.stats;

  return(
    <div style={{minHeight:"100vh",background:"#0f1f0f",color:"#e8ead4",fontFamily:"Georgia,serif"}}>
      <div className="safe-top" style={{background:"linear-gradient(180deg,#1a2e1a,#0f1f0f)",borderBottom:"1px solid #2d4a1e",padding:"11px 16px",display:"flex",alignItems:"center",gap:"10px"}}>
        <span style={{fontSize:"20px"}}>🌄</span>
        <div>
          <div style={{fontSize:"15px",fontWeight:"bold",color:"#F5C842",letterSpacing:"1px"}}>RanchoPlan IA</div>
          <div style={{fontSize:"8px",color:"#789060",textTransform:"uppercase",letterSpacing:"2px"}}>Los Altos de Jalisco · DEM + Hidrología + Solar</div>
        </div>
        {phase!=="home"&&<button onClick={resetAll} style={{marginLeft:"auto",background:"transparent",border:"1px solid #3a5a2a",color:"#aac080",padding:"5px 11px",borderRadius:"20px",cursor:"pointer",fontSize:"11px"}}>← Inicio</button>}
      </div>

      {error&&<div style={{background:"#4a1010",border:"1px solid #8b2020",margin:"8px 14px",padding:"8px 14px",borderRadius:"8px",fontSize:"12px",color:"#ffaaaa"}}>⚠️ {error}<button onClick={()=>setError("")} style={{float:"right",background:"none",border:"none",color:"#ffaaaa",cursor:"pointer",fontSize:"16px"}}>✕</button></div>}

      {/* HOME */}
      {phase==="home"&&<div style={{maxWidth:"440px",margin:"0 auto",padding:"28px 16px",textAlign:"center"}}>
        <div style={{fontSize:"52px",marginBottom:"8px"}}>🏔️</div>
        <h1 style={{fontSize:"21px",color:"#F5C842",marginBottom:"8px"}}>RanchoPlan IA</h1>
        <p style={{color:"#8a9a70",fontSize:"12px",lineHeight:"1.75",marginBottom:"20px"}}>Levantamiento topográfico GPS · DEM · Hidrología D8 · Orientación solar · UTM WGS84</p>
        <div style={{display:"flex",flexDirection:"column",gap:"10px",marginBottom:"18px"}}>
          <button onClick={()=>{setPhase("tracking");startGPS();}} style={{background:"linear-gradient(135deg,#2d5a27,#3d7a35)",color:"#fff",border:"none",padding:"15px",borderRadius:"12px",fontSize:"15px",cursor:"pointer"}}>📍 Iniciar Levantamiento GPS</button>
          <button onClick={()=>{setPhase("tracking");startDemo();}} style={{background:"#1a2e1a",color:"#ccd8a0",border:"1px solid #3a5a2a",padding:"12px",borderRadius:"12px",fontSize:"12px",cursor:"pointer"}}>🎭 Demo — barrido en cuadrícula</button>
        </div>
        <div style={{background:"#2a1a0a",border:"1px solid #6a3a10",borderRadius:"10px",padding:"12px",marginBottom:"14px",textAlign:"left"}}>
          <div style={{fontSize:"10px",color:"#e09050",fontWeight:"bold",marginBottom:"6px"}}>⚠️ Para generar el plan con IA</div>
          <div style={{fontSize:"11px",color:"#a07850",lineHeight:"1.6",marginBottom:"8px"}}>
            CodePen bloquea la API. Para que funcione el botón "🤖 Plan", abre la app desde <strong style={{color:"#F5C842"}}>Glitch.com</strong>:
          </div>
          <div style={{fontSize:"10px",color:"#789060",lineHeight:"1.7"}}>
            1. Ve a <strong>glitch.com/edit/#!/remix/hello-webpage</strong><br/>
            2. Abre <strong>index.html</strong> → borra todo → pega el código<br/>
            3. Toca <strong>"Show → In a new window"</strong><br/>
            4. Esa URL funciona con GPS + API ✅
          </div>
        </div>
        <div style={{display:"none"}}>
        </div>
        <div style={{background:"#1a2e1a",borderRadius:"12px",padding:"13px",textAlign:"left"}}>
          <div style={{fontSize:"10px",color:"#789060",textTransform:"uppercase",letterSpacing:"1px",marginBottom:"8px"}}>Protocolo de levantamiento</div>
          {["1. Camina el perímetro completo","2. Recorre el interior en franjas paralelas N-S cada 8-10 m","3. Marca 🌳 junto a cada árbol relevante","4. Marca 📍 accesos, agua, construcciones existentes","5. Con 12+ puntos el análisis DEM se activa","6. El plan usa hidrología real, solar y pendientes"].map((t,i)=>(
            <div key={i} style={{fontSize:"11px",color:"#8a9a70",marginBottom:"4px"}}>{t}</div>
          ))}
        </div>
      </div>}

      {/* TRACKING */}
      {phase==="tracking"&&<div style={{padding:"11px",maxWidth:"480px",margin:"0 auto"}}>
        <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:"5px",marginBottom:"8px"}}>
          {[[points.length,"PUNTOS"],[(isNaN(distVal)?0:distVal)+"m","RECORRIDO"],[isNaN(areaVal/10000)?"0.00":(areaVal/10000).toFixed(2)+"ha","ÁREA"],[trees.length+"🌳 "+pois.length+"📍","MARCAS"]].map(([v2,l])=>(
            <div key={l} style={{background:"#1a2e1a",borderRadius:"7px",padding:"6px",textAlign:"center"}}>
              <div style={{fontSize:"13px",fontWeight:"bold",color:"#F5C842"}}>{v2}</div>
              <div style={{fontSize:"8px",color:"#789060"}}>{l}</div>
            </div>
          ))}
        </div>

        {utmLive&&<div style={{background:"#1a2e1a",borderRadius:"7px",padding:"6px 10px",marginBottom:"7px",fontSize:"9px",color:"#5a9060",display:"flex",gap:"6px",alignItems:"center"}}>
          <span style={{color:"#F5C842"}}>📍 UTM</span>
          <span style={{fontFamily:"monospace",color:"#a0c080"}}>{utmLive.str}</span>
          {analysis&&<span style={{marginLeft:"auto",color:"#4CAF50",fontSize:"9px"}}>✅ DEM activo</span>}
        </div>}

        <div style={{display:"flex",gap:"6px",marginBottom:"7px",flexWrap:"wrap"}}>
          {isTracking
            ?<button onClick={demoMode?stopDemo:stopGPS} style={{background:"#8b2020",color:"#fff",border:"none",padding:"10px 13px",borderRadius:"8px",cursor:"pointer",fontSize:"12px",fontWeight:"bold"}}>⏹ Pausar</button>
            :<button onClick={demoMode?startDemo:startGPS} style={{background:"#2d5a27",color:"#fff",border:"none",padding:"10px 13px",borderRadius:"8px",cursor:"pointer",fontSize:"12px"}}>▶ Continuar</button>
          }
          <button onClick={handleMarkTree} style={{flex:1,background:"linear-gradient(135deg,#1a4a1a,#2a7a2a)",color:"#a0e080",border:"2px solid #3a8a3a",padding:"10px 8px",borderRadius:"8px",cursor:"pointer",fontSize:"12px",fontWeight:"bold"}}>🌳 Árbol</button>
          <button onClick={handleMarkPOI} style={{flex:1,background:"linear-gradient(135deg,#4a2a0a,#8a5a1a)",color:"#e0c080",border:"2px solid #8a5a0a",padding:"10px 8px",borderRadius:"8px",cursor:"pointer",fontSize:"12px",fontWeight:"bold"}}>📍 POI</button>
          {points.length>=12&&!isTracking&&(
            <button onClick={generatePlan} disabled={loading} style={{background:loading?"#2a3a1a":"linear-gradient(135deg,#8B6914,#F5C842)",color:loading?"#789060":"#1a1a0a",border:"none",padding:"10px 13px",borderRadius:"8px",cursor:loading?"not-allowed":"pointer",fontSize:"12px",fontWeight:"bold"}}>
              {loading?"⏳":"🤖 Plan"}
            </button>
          )}
        </div>

        {/* Botón reiniciar recorrido GPS */}
        <div style={{display:"flex",gap:"6px",marginBottom:"7px",alignItems:"center"}}>
          <button onClick={resetGPS} disabled={isTracking}
            style={{background:isTracking?"#1a1a1a":"#2a1a0a",color:isTracking?"#555":"#e09050",border:"2px solid "+(isTracking?"#333":"#6a3a10"),padding:"8px 14px",borderRadius:"8px",cursor:isTracking?"not-allowed":"pointer",fontSize:"12px",fontWeight:"bold"}}>
            🔄 Reiniciar recorrido
          </button>
          <div style={{flex:1,fontSize:"9px",color:"#5a6a50",lineHeight:"1.4"}}>
            {isTracking?"Pausa primero":points.length>0?"Borra "+points.length+" pts · conserva "+trees.length+"🌳 "+pois.length+"📍":"Sin recorrido"}
          </div>
        </div>

        <div style={{display:"flex",gap:"4px",marginBottom:"6px"}}>
          {[["dem","🗺 DEM"],["slope","📐 Pendiente"],["solar","☀️ Solar"],["hidro","💧 Hidrología"],["gps","📍 GPS"]].map(([id,lbl])=>(
            <button key={id} onClick={()=>setMapLayer(id)} style={{flex:1,padding:"4px 2px",borderRadius:"6px",border:mapLayer===id?"2px solid #F5C842":"1px solid #2a3a1a",background:mapLayer===id?"#2d4a1e":"#1a2e1a",color:mapLayer===id?"#F5C842":"#789060",cursor:"pointer",fontSize:"9px"}}>
              {lbl}
            </button>
          ))}
        </div>

        <div style={{display:"flex",alignItems:"center",gap:"7px",marginBottom:"6px",fontSize:"10px",color:isTracking?"#4CAF50":"#888"}}>
          <div style={{width:"7px",height:"7px",borderRadius:"50%",background:isTracking?"#4CAF50":"#555",animation:isTracking?"pulse 1s infinite":"none"}}/>
          {isTracking?(demoMode?"Simulando barrido en cuadrícula…":"📡 GPS activo — sigue el protocolo de franjas"):points.length>=12?"Análisis DEM completo — listo para generar plan":points.length>0?`Puntos: ${points.length}/12 mínimo`:"Listo para iniciar"}
        </div>

        <canvas ref={canvasRef} width={440} height={300} style={{width:"100%",borderRadius:"11px",background:"#0a1a0a",border:"1px solid #2a3a1a",display:"block",marginBottom:"7px"}}/>

        {/* Panel de análisis */}
        {as&&<div style={{background:"#1a2e1a",borderRadius:"10px",padding:"10px",marginBottom:"7px"}}>
          <div style={{fontSize:"10px",color:"#F5C842",marginBottom:"7px",textTransform:"uppercase",letterSpacing:"1px",fontWeight:"bold"}}>Análisis topográfico en tiempo real</div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:"6px",marginBottom:"7px"}}>
            {[["🟢","Plano",as.pctFlat+"%","Cultivos"],["🟡","Suave",as.pctGentle+"%","Ganadería"],["🔴","Pend.",as.pctSteep+"%","Conservar"],["☀️","Solar",as.pctSolarHigh+"%","Frutales"],["🌑","Sombra",as.pctShade+"%","Animales"],["💧","Hídrico",as.sinkCount+" zonas","Reservorio"]].map(([ic,lbl,val,hint])=>(
              <div key={lbl} style={{background:"#0f1f0f",borderRadius:"7px",padding:"6px",textAlign:"center"}}>
                <div style={{fontSize:"14px"}}>{ic}</div>
                <div style={{fontSize:"11px",fontWeight:"bold",color:"#F5C842"}}>{val}</div>
                <div style={{fontSize:"8px",color:"#789060"}}>{lbl}</div>
                <div style={{fontSize:"8px",color:"#4a6a4a"}}>{hint}</div>
              </div>
            ))}
          </div>
          <div style={{fontSize:"9px",color:"#5a7050"}}>
            Altitud: {as.elevRange} · Aptitud reservorio: <span style={{color:as.reservoirSuitability==="alta"?"#4CAF50":as.reservoirSuitability==="media"?"#F1C40F":"#E74C3C"}}>{as.reservoirSuitability}</span> · Cultivos: <span style={{color:as.cropSuitability==="alta"?"#4CAF50":"#F1C40F"}}>{as.cropSuitability}</span>
          </div>
        </div>}

        {trees.length>0&&<div style={{background:"#1a2e1a",borderRadius:"9px",padding:"9px",marginBottom:"6px"}}>
          <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Árboles ({trees.length}) · POIs ({pois.length})</div>
          <div style={{maxHeight:"80px",overflowY:"auto"}}>
            {[...trees.map(t=>({...t,_type:"tree"})),...pois.map(p=>({...p,_type:"poi"}))].map((item,i)=>(
              <div key={i} style={{display:"flex",gap:"6px",alignItems:"center",fontSize:"10px",marginBottom:"2px",color:item._type==="tree"?"#a0c080":"#e0a060"}}>
                <span>{item.icon}</span><span style={{flex:1}}>{item.name||item.label}</span>
                <span style={{fontFamily:"monospace",fontSize:"8px",color:"#5a7050"}}>{latLngToUTM(item.lat,item.lng).easting}E</span>
              </div>
            ))}
          </div>
        </div>}

        {points.length>0&&points.length<12&&!isTracking&&<div style={{padding:"8px",background:"#2a2a1a",borderRadius:"7px",fontSize:"10px",color:"#a09050",textAlign:"center"}}>
          {points.length} puntos registrados — necesitas 12+ para análisis DEM completo. Sigue caminando el interior en franjas.
        </div>}

        {loading&&<div style={{textAlign:"center",padding:"14px",color:"#F5C842"}}>
          <div style={{fontSize:"26px",animation:"spin 1s linear infinite",display:"inline-block"}}>⚙️</div>
          <div style={{marginTop:"7px",fontSize:"12px"}}>Procesando DEM + hidrología + solar → generando plan…</div>
        </div>}
      </div>}

      {/* TREE MODAL */}
      {treeModal&&<div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",display:"flex",alignItems:"flex-end",zIndex:200}}>
        <div style={{background:"#1a2e1a",borderRadius:"20px 20px 0 0",padding:"18px 16px 28px",width:"100%",maxWidth:"480px",margin:"0 auto",border:"1px solid #3a5a2a",borderBottom:"none"}}>
          <div style={{textAlign:"center",fontSize:"26px",marginBottom:"2px"}}>🌳</div>
          <h3 style={{color:"#F5C842",textAlign:"center",marginBottom:"2px",fontSize:"15px"}}>Registrar Árbol</h3>
          {pendingPos&&<p style={{color:"#5a9060",fontSize:"9px",textAlign:"center",marginBottom:"10px",fontFamily:"monospace"}}>{latLngToUTM(pendingPos.lat,pendingPos.lng).str}</p>}
          <div style={{marginBottom:"10px"}}>
            <div style={{fontSize:"9px",color:"#789060",marginBottom:"4px",textTransform:"uppercase",letterSpacing:"1px"}}>Nombre (opcional)</div>
            <input value={treeName} onChange={e=>setTreeName(e.target.value)} placeholder="ej. Encino del pozo…" style={{width:"100%",background:"#0f1f0f",border:"1px solid #2a3a1a",borderRadius:"7px",padding:"7px 10px",color:"#e8ead4",fontSize:"12px",outline:"none"}}/>
          </div>
          <div style={{marginBottom:"10px"}}>
            <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Tipo *</div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:"4px"}}>
              {TREE_TYPES.map(t=>(
                <button key={t.id} onClick={()=>setTreeType(t.id)} style={{padding:"6px 3px",borderRadius:"7px",border:treeType===t.id?"2px solid #F5C842":"1px solid #2a3a1a",background:treeType===t.id?"#2d4a1e":"#0f1f0f",color:treeType===t.id?"#F5C842":"#8a9a70",cursor:"pointer",fontSize:"10px",textAlign:"center"}}>
                  <div style={{fontSize:"15px"}}>{t.icon}</div><div>{t.label}</div>
                </button>
              ))}
            </div>
          </div>
          <div style={{marginBottom:"14px"}}>
            <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Tamaño *</div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:"4px"}}>
              {TREE_SIZES.map(s=>(
                <button key={s.id} onClick={()=>setTreeSize(s.id)} style={{padding:"6px 2px",borderRadius:"7px",border:treeSize===s.id?"2px solid #F5C842":"1px solid #2a3a1a",background:treeSize===s.id?"#2d4a1e":"#0f1f0f",color:treeSize===s.id?"#F5C842":"#8a9a70",cursor:"pointer",fontSize:"9px",textAlign:"center"}}>
                  <div style={{fontWeight:"bold"}}>{s.label}</div><div style={{fontSize:"8px",opacity:.7}}>{s.sub}</div>
                </button>
              ))}
            </div>
          </div>
          <div style={{display:"flex",gap:"8px"}}>
            <button onClick={()=>setTreeModal(false)} style={{flex:1,padding:"10px",borderRadius:"8px",border:"1px solid #3a3a2a",background:"transparent",color:"#789060",cursor:"pointer",fontSize:"12px"}}>Cancelar</button>
            <button onClick={confirmTree} style={{flex:2,padding:"10px",borderRadius:"8px",border:"none",background:treeType&&treeSize?"linear-gradient(135deg,#2d7a2d,#4aaa3a)":"#2a3a2a",color:treeType&&treeSize?"#fff":"#789060",cursor:treeType&&treeSize?"pointer":"not-allowed",fontSize:"13px",fontWeight:"bold"}}>🌳 Guardar</button>
          </div>
        </div>
      </div>}

      {/* POI MODAL */}
      {poiModal&&<div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",display:"flex",alignItems:"flex-end",zIndex:200}}>
        <div style={{background:"#1a2e1a",borderRadius:"20px 20px 0 0",padding:"18px 16px 28px",width:"100%",maxWidth:"480px",margin:"0 auto",border:"1px solid #5a4a1a",borderBottom:"none"}}>
          <div style={{textAlign:"center",fontSize:"26px",marginBottom:"2px"}}>📍</div>
          <h3 style={{color:"#F5C842",textAlign:"center",marginBottom:"2px",fontSize:"15px"}}>Punto de Interés</h3>
          {pendingPos&&<p style={{color:"#9a7050",fontSize:"9px",textAlign:"center",marginBottom:"10px",fontFamily:"monospace"}}>{latLngToUTM(pendingPos.lat,pendingPos.lng).str}</p>}
          <div style={{marginBottom:"10px"}}>
            <div style={{fontSize:"9px",color:"#789060",marginBottom:"4px",textTransform:"uppercase",letterSpacing:"1px"}}>Nombre / descripción (opcional)</div>
            <input value={poiName} onChange={e=>setPoiName(e.target.value)} placeholder="ej. Entrada norte, Pozo antiguo…" style={{width:"100%",background:"#0f1f0f",border:"1px solid #2a3a1a",borderRadius:"7px",padding:"7px 10px",color:"#e8ead4",fontSize:"12px",outline:"none"}}/>
          </div>
          <div style={{marginBottom:"14px"}}>
            <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Tipo *</div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:"4px"}}>
              {POI_TYPES.map(t=>(
                <button key={t.id} onClick={()=>setPoiType(t.id)} style={{padding:"8px 4px",borderRadius:"7px",border:poiType===t.id?"2px solid #F5C842":"1px solid #2a3a1a",background:poiType===t.id?"#3a3a0e":"#0f1f0f",color:poiType===t.id?"#F5C842":"#8a9a70",cursor:"pointer",fontSize:"10px",textAlign:"center"}}>
                  <div style={{fontSize:"18px"}}>{t.icon}</div><div>{t.label}</div>
                </button>
              ))}
            </div>
          </div>
          <div style={{display:"flex",gap:"8px"}}>
            <button onClick={()=>setPoiModal(false)} style={{flex:1,padding:"10px",borderRadius:"8px",border:"1px solid #3a3a2a",background:"transparent",color:"#789060",cursor:"pointer",fontSize:"12px"}}>Cancelar</button>
            <button onClick={confirmPOI} style={{flex:2,padding:"10px",borderRadius:"8px",border:"none",background:poiType?"linear-gradient(135deg,#7a5a1a,#c09030)":"#2a3a2a",color:poiType?"#fff":"#789060",cursor:poiType?"pointer":"not-allowed",fontSize:"13px",fontWeight:"bold"}}>📍 Guardar POI</button>
          </div>
        </div>
      </div>}

      {/* MASTER PLAN */}
      {phase==="masterplan"&&masterPlan&&<div style={{padding:"12px",maxWidth:"520px",margin:"0 auto"}}>
        <h2 style={{fontSize:"15px",color:"#F5C842",marginBottom:"2px"}}>Master Plan</h2>
        <p style={{color:"#789060",fontSize:"9px",marginBottom:"11px"}}>{points.length} pts · DEM interpolado · Hidrología D8 · Orientación solar · {trees.length} árboles · {pois.length} POIs</p>
        <div style={{display:"flex",gap:"5px",marginBottom:"11px"}}>
          {masterPlan.variantes.map((v2,i)=>(
            <button key={i} onClick={()=>setSelV(i)} style={{flex:1,padding:"8px 4px",borderRadius:"8px",border:selV===i?"2px solid #F5C842":"1px solid #2a3a1a",background:selV===i?"#2d4a1e":"#1a2e1a",color:selV===i?"#F5C842":"#8a9a70",cursor:"pointer",fontSize:"8px",textAlign:"center"}}>
              Opción {i+1}<div style={{fontWeight:"bold",marginTop:"2px",fontSize:"9px",color:selV===i?"#F5C842":"#aaa"}}>{v2.nombre?.split(" ").slice(0,3).join(" ")}</div>
            </button>
          ))}
        </div>
        {(()=>{
          const v=masterPlan.variantes[selV];if(!v)return null;
          return <div>
            <div style={{background:"#1a2e1a",borderRadius:"11px",padding:"12px",marginBottom:"8px"}}>
              <div style={{fontSize:"14px",color:"#F5C842",marginBottom:"4px"}}>{v.nombre}</div>
              <div style={{fontSize:"11px",color:"#a0b880",lineHeight:"1.6",marginBottom:"8px"}}>{v.descripcion}</div>
              {v.topografia_aprovechada&&<div style={{fontSize:"10px",color:"#789060",background:"#0f1f0f",borderRadius:"6px",padding:"6px",marginBottom:"5px"}}>🗻 {v.topografia_aprovechada}</div>}
              {v.arboles_integrados&&trees.length>0&&<div style={{fontSize:"10px",color:"#789060",background:"#0f1f0f",borderRadius:"6px",padding:"6px",marginBottom:"6px"}}>🌳 {v.arboles_integrados}</div>}
              <div style={{display:"flex",gap:"5px",flexWrap:"wrap"}}>
                <span style={{background:"#2d4a1e",color:"#a0c060",padding:"2px 7px",borderRadius:"20px",fontSize:"9px"}}>💰 ${((v.inversion_total_mxn||0)/1e6).toFixed(1)}M MXN</span>
                <span style={{background:"#2d4a1e",color:"#a0c060",padding:"2px 7px",borderRadius:"20px",fontSize:"9px"}}>📐 {isNaN(areaVal/10000)?"—":(areaVal/10000).toFixed(2)} ha</span>
                {as&&<span style={{background:"#2d4a1e",color:"#a0c060",padding:"2px 7px",borderRadius:"20px",fontSize:"9px"}}>🟢 {as.pctFlat}% plano</span>}
              </div>
            </div>
            <div style={{marginBottom:"8px"}}>
              <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Zonificación con justificación topográfica</div>
              {v.zonas?.map((z,i)=>(
                <div key={i} style={{background:"#1a2e1a",borderLeft:`4px solid ${ZONE_COLORS[z.id]||"#4a4"}`,borderRadius:"7px",padding:"7px 9px",display:"flex",gap:"7px",alignItems:"flex-start",marginBottom:"4px"}}>
                  <span style={{fontSize:"16px",flexShrink:0}}>{ZONE_ICONS[z.id]||"📍"}</span>
                  <div style={{flex:1}}>
                    <div style={{fontWeight:"bold",fontSize:"11px",color:"#c0d090",marginBottom:"1px"}}>{z.nombre}</div>
                    <div style={{fontSize:"9px",color:"#789060",marginBottom:"2px"}}>
                      📍 {z.ubicacion} · {z.area_m2?.toLocaleString()} m²
                      {z.pendiente_pct!=null&&<span> · 📐 {z.pendiente_pct}%</span>}
                      {z.orientacion_solar&&<span> · ☀️ {z.orientacion_solar}</span>}
                    </div>
                    <div style={{fontSize:"10px",color:"#8a9870",lineHeight:"1.5"}}>{z.justificacion}</div>
                    {z.distancia_a&&<div style={{fontSize:"9px",color:"#5a8a7a",marginTop:"2px"}}>📏 {z.distancia_a}</div>}
                    {z.notas_bienestar&&<div style={{fontSize:"9px",color:"#7a9a5a",marginTop:"2px"}}>🐾 {z.notas_bienestar}</div>}
                  </div>
                  <span style={{fontSize:"8px",color:z.prioridad==="alta"?"#F5C842":z.prioridad==="media"?"#a0c060":"#789060",flexShrink:0,textTransform:"uppercase",fontWeight:"bold"}}>{z.prioridad}</span>
                </div>
              ))}
            </div>
            {v.fases?.length>0&&<div style={{background:"#1a2e1a",borderRadius:"9px",padding:"10px",marginBottom:"8px"}}>
              <div style={{fontSize:"9px",color:"#789060",marginBottom:"6px",textTransform:"uppercase",letterSpacing:"1px"}}>Fases</div>
              {v.fases.map((f,i)=>(
                <div key={i} style={{display:"flex",gap:"8px",alignItems:"center",marginBottom:"4px",fontSize:"11px"}}>
                  <span style={{background:"#F5C842",color:"#1a1a0a",borderRadius:"50%",width:"18px",height:"18px",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:"bold",fontSize:"8px",flexShrink:0}}>{f.fase}</span>
                  <div style={{flex:1}}><span style={{color:"#c0d090",fontWeight:"bold"}}>{f.nombre}</span><span style={{color:"#789060"}}> · {f.duracion}</span></div>
                  <span style={{color:"#F5C842",fontSize:"10px",flexShrink:0}}>${((f.inversion_mxn||0)/1e6).toFixed(1)}M</span>
                </div>
              ))}
            </div>}
            {v.consideraciones?.length>0&&<div style={{background:"#1a2e1a",borderRadius:"9px",padding:"10px",marginBottom:"10px"}}>
              <div style={{fontSize:"9px",color:"#789060",marginBottom:"5px",textTransform:"uppercase",letterSpacing:"1px"}}>Consideraciones</div>
              {v.consideraciones.map((c,i)=><div key={i} style={{fontSize:"10px",color:"#a0b880",marginBottom:"4px",paddingLeft:"8px",borderLeft:"2px solid #3d5a2a"}}>• {c}</div>)}
            </div>}
            <div style={{display:"flex",gap:"7px",flexDirection:"column"}}>
              <button onClick={exportPDF} style={{width:"100%",background:"linear-gradient(135deg,#8B6914,#F5C842)",color:"#1a1a0a",border:"none",padding:"13px",borderRadius:"11px",fontSize:"14px",fontWeight:"bold",cursor:"pointer"}}>
                📄 PDF — Plano topográfico + UTM
              </button>
              <button onClick={exportKML} style={{width:"100%",background:"linear-gradient(135deg,#1a3a6a,#2a6aaa)",color:"#fff",border:"none",padding:"11px",borderRadius:"11px",fontSize:"13px",fontWeight:"bold",cursor:"pointer"}}>
                🌐 KML — Google Earth (recorrido + zonas + árboles + hidrología)
              </button>
            </div>
          </div>;
        })()}
      </div>}

      <div className="safe-bot" style={{height:"16px"}}/>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
